# Copy this file to .shopify_backend.env and set your Gemini key when ready.
#
# The start script auto-loads this file:
#   scripts/start_shopify_backend.sh

# Optional: "auto" (default), "mock", or "gemini"
SHOPIFY_BACKEND_MODE=auto

# Optional: choose Gemini model. If empty, backend tries multiple models.
GEMINI_MODEL=

# Set this when you are ready to enable Gemini:
GEMINI_API_KEY=
